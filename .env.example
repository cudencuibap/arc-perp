# Arc Perp production/local template.
# Copy to .env locally. Never commit real keys, mnemonics, or secrets.
#
# Arc testnet quick reference:
#   Faucet:   https://faucet.circle.com   (USDC is the native gas token on Arc)
#   Explorer: https://testnet.arcscan.app
#   USDC:     0x3600000000000000000000000000000000000000 (canonical, 6 decimals)

NODE_ENV=production
MATCHING_ENGINE_PORT=4101
WEBSOCKET_GATEWAY_PORT=4100
PRICE_ENGINE_PORT=4102
MARKET_DATA_PORT=4102
RISK_ENGINE_PORT=4103
LIQUIDATION_ENGINE_PORT=4104

MATCHING_ENGINE_URL=http://localhost:4101
MATCHING_ENGINE_WS=ws://localhost:4101/stream
MARKET_DATA_HTTP_URL=http://localhost:4102
MARKET_DATA_WS=ws://localhost:4102/stream

BINANCE_WS_URL=wss://stream.binance.com:9443/stream?streams=btcusdt@ticker/ethusdt@ticker/solusdt@ticker
CHAINLINK_RPC_URL=
CHAINLINK_FEED_ADDRESSES=BTC-PERP=,ETH-PERP=,SOL-PERP=
CHAINLINK_STREAMS_URL=
CHAINLINK_FEED_IDS=BTC-PERP=,ETH-PERP=,SOL-PERP=
CHAINLINK_API_KEY=
CHAINLINK_API_SECRET=

VITE_WS_URL=ws://localhost:4100/ws
VITE_MATCHING_ENGINE_URL=http://localhost:4101
VITE_MARKET_DATA_URL=http://localhost:4102
VITE_ONCHAIN_CONFIG_URL=http://localhost:4100/api/onchain/config
VITE_WALLETCONNECT_PROJECT_ID=

SETTLEMENT_SERVICE_PORT=4105
SETTLEMENT_SERVICE_URL=http://localhost:4105
ARC_RPC_URL=https://rpc.testnet.arc.network
# Public Arc testnet contract addresses — same on every deployment. Pre-filled for convenience.
ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
COLLATERAL_VAULT_ADDRESS=0xEBa02c6911c35E5dB6b984Bb49dB9F281C181c70
PERP_SETTLEMENT_ADDRESS=0xc7BA31Fd7284491b1a93bd046361F76FfDD5a915
TREASURY_VAULT_ADDRESS=0xe69d693968b3626C49D600f6fFaF8682F63b1ba5

# Required only for settlement operator deployments. Use provider secrets, not Git.
# Generate locally with: node -e "console.log('0x'+require('crypto').randomBytes(32).toString('hex'))"
SETTLEMENT_PRIVATE_KEY=

# Required only for autonomous onchain agent wallets.
AGENT_WALLET_SECRET=
AGENT_WALLET_DIR=./data/agent-wallets
AGENT_AUTO_DEPOSIT_USDC=0
MARKET_MAKER_AGENT_COUNT=6
MARKET_MAKER_INTERVAL_MS=1800
TRADER_AGENT_COUNT=4
TRADER_INTERVAL_MS=2500
FUNDING_SETTLEMENT_INTERVAL_MS=30000

# Phase 2b — matching-engine real-balance gate. Flip to "true" only after
# agents are funded on-chain (AGENT_AUTO_DEPOSIT_USDC > 0); otherwise every
# agent order will reject with INSUFFICIENT_MARGIN. See docs/settlement.md.
ENGINE_USE_REAL_BALANCE=false
# Base units (6-dec USDC) reserved as gas-only per wallet; never lockable
# as margin. Arc uses USDC as native gas. 100000 = 0.1 USDC.
ENGINE_GAS_RESERVE_USDC_BASE_UNITS=100000
# Settlement service URL the matching-engine reads /balances/:addr from.
SETTLEMENT_SERVICE_URL=http://localhost:4105
