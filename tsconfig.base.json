{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@arc-perp/core": ["packages/core/dist/index.d.ts"],
      "@arc-perp/core/onchain": ["packages/core/dist/onchain.d.ts"]
    },
    "declaration": true,
    "sourceMap": true
  }
}
